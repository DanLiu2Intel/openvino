diff --git a/src/plugins/intel_npu/src/utils/src/vm/npu_vm_runtime_api.cpp b/src/plugins/intel_npu/src/utils/src/vm/npu_vm_runtime_api.cpp
index 222f995c399..8460bfaa086 100644
--- a/src/plugins/intel_npu/src/utils/src/vm/npu_vm_runtime_api.cpp
+++ b/src/plugins/intel_npu/src/utils/src/vm/npu_vm_runtime_api.cpp
@@ -5,6 +5,8 @@
 #include "intel_npu/utils/vm/npu_vm_runtime_api.hpp"
 
 #include <algorithm>
